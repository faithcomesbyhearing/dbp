{
    "name": "laravel/laravel",
    "description": "The Laravel Framework",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.4",
        "anhskohbo/no-captcha": "3.8.0",
        "awobaz/compoships": "3.0.1",
        "aws/aws-sdk-php": "3.373.3",
        "bugsnag/bugsnag-laravel": "2.30.0",
        "geoip2/geoip2": "3.3.0",
        "guzzlehttp/guzzle": "7.10.0",
        "intervention/image-laravel": "4.0.0",
        "laravel/framework": "13.12.0",
        "laravel/slack-notification-channel": "3.8.0",
        "laravel/socialite": "5.27.0",
        "laravel/tinker": "3.0.2",
        "mcamara/laravel-localization": "2.4.0",
        "socialiteproviders/generators": "4.8.0",
        "socialiteproviders/google": "4.1.0",
        "spatie/array-to-xml": "3.4.4",
        "spatie/eloquent-sortable": "5.0.1",
        "spatie/laravel-fractal": "6.4.0",
        "sunra/php-simple-html-dom-parser": "1.5.2",
        "symfony/http-client": "8.0.13",
        "symfony/psr-http-message-bridge": "8.0.8",
        "symfony/yaml": "8.0.13",
        "torann/geoip": "3.0.10",
        "yosymfony/toml": "1.0.4",
        "zircote/swagger-php": "4.11.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "4.2.8",
        "barryvdh/laravel-ide-helper": "3.7.0",
        "fakerphp/faker": "1.24.1",
        "filp/whoops": "2.18.4",
        "friendsofphp/php-cs-fixer": "3.94.2",
        "itsgoingd/clockwork": "5.3.5",
        "mockery/mockery": "1.6.12",
        "phpunit/phpunit": "12.5.28",
        "spatie/laravel-tail": "4.6.0",
        "squizlabs/php_codesniffer": "3.13.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "cs": [
            "php-cs-fixer fix --dry-run"
        ],
        "cs-fix": [
            "php-cs-fixer fix"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": false
        },
        "platform": {
            "php": "8.4.0"
        }
    }
}
